{
  "name": "@pixelhub/server",
  "version": "0.1.0",
  "private": true,
  "description": "pixelhub Colyseus world server",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@colyseus/schema": "^2.0.37",
    "@colyseus/tools": "^0.15.49",
    "@pixelhub/shared": "workspace:*",
    "colyseus": "^0.15.57",
    "express": "^4.22.2",
    "livekit-server-sdk": "^2.17.0",
    "prom-client": "^15.1.3"
  },
  "devDependencies": {
    "@colyseus/testing": "^0.15.4",
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.12",
    "colyseus.js": "^0.15.28",
    "tsx": "^4.19.2",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
